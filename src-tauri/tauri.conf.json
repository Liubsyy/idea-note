{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Idea Note",
  "identifier": "com.liubs.idea-note",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Idea Note",
        "width": 960,
        "height": 640,
        "minWidth": 640,
        "minHeight": 420,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "fileAssociations": [
      {
        "ext": [
          "md", "markdown", "mdown", "mkd", "mdx", "txt", "text", "log",
          "json", "jsonc", "json5", "yaml", "yml", "toml", "xml", "csv", "tsv",
          "ini", "conf", "cfg", "env", "properties",
          "js", "jsx", "mjs", "cjs", "ts", "tsx", "html", "htm", "css", "scss",
          "sass", "less", "vue", "svelte", "astro",
          "py", "rs", "go", "java", "kt", "kts", "c", "h", "cpp", "cc", "cxx",
          "hpp", "cs", "rb", "php", "sh", "bash", "zsh", "fish", "ps1", "bat",
          "sql", "swift", "lua", "r", "pl", "dart", "scala", "clj", "ex", "exs",
          "gradle", "tex", "bib", "rst", "adoc", "org"
        ],
        "name": "Idea Note Text Document",
        "description": "Text, markdown and code files",
        "mimeType": "text/plain",
        "role": "Editor"
      },
      {
        "ext": ["png", "jpg", "jpeg", "gif", "webp", "bmp", "svg"],
        "name": "Idea Note Image",
        "description": "Image files",
        "mimeType": "image/png",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}


